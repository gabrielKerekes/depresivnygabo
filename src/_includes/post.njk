---
layout: base.njk
---
{% from "macros.njk" import topicTags, stageBadge %}
{# Structured data so reader-mode extractors that parse JSON-LD (Firefox/Safari)
   get a clean headline, byline and date without relying on <title> heuristics. #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "author": { "@type": "Person", "name": {{ site.author | dump | safe }} },
  "datePublished": "{{ date | htmlDateString }}",
  {% if updated %}"dateModified": "{{ updated | htmlDateString }}",{% endif %}
  "url": "{{ site.url }}{{ page.url }}"
}
</script>

{% set toc = content | toc %}
<div class="post-layout">
  {% if toc %}
  <aside class="post-toc">
    <details class="toc-details">
      <summary>Obsah</summary>
      <nav class="toc-body" aria-label="Obsah článku">
        {{ toc | safe }}
      </nav>
    </details>
  </aside>
  {# Progressive enhancement: the TOC stays collapsed by default (mobile), and
     opens automatically once there's room for the sidebar. Without JS it stays
     a tappable "Obsah" disclosure everywhere. #}
  <script>
    (function () {
      var d = document.querySelector(".toc-details");
      if (!d || !window.matchMedia) return;
      var mq = window.matchMedia("(min-width: 64rem)");
      function sync() {
        d.open = mq.matches;
      }
      sync();
      mq.addEventListener("change", sync);
    })();
  </script>
  {% endif %}
  <article class="post">
  <header class="post-header">
    <h1>{{ title }}</h1>
    <p class="post-meta">
      {%- if updated %}
      <time datetime="{{ date | htmlDateString }}">zasadené {{ date | readableDate }}</time>
      <span class="dot" aria-hidden="true">·</span>
      <time class="tended" datetime="{{ updated | htmlDateString }}">naposledy zaliate {{ updated | readableDate }}</time>
      {%- else %}
      <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
      {%- endif %}
      <span class="dot" aria-hidden="true">·</span>
      <span class="post-readtime">{{ content | readingTime }} min čítania</span>
      {{- stageBadge(stage) -}}
    </p>
  </header>

  {% set stageMeta = stage | stageInfo %}
  {% if stageMeta and stageMeta.banner %}
  <p class="stage-banner stage-{{ stage }}">{{ stageMeta.banner }}</p>
  {% endif %}

  {{ content | safe }}

  {% if tags %}
  <footer class="post-footer">
    {{ topicTags(tags) }}
  </footer>
  {% endif %}
  </article>
</div>

<p class="back"><a href="/">← späť na všetky články</a></p>
