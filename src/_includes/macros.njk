{# Growth-stage badge (🌱 / 🌿 / 🌳) for a post's `stage:` front-matter. #}
{% macro stageBadge(stage) %}
{%- set s = stage | stageInfo -%}
{%- if s %} <span class="stage-badge stage-{{ stage }}" title="{{ s.description }}">{{ s.emoji }} {{ s.label }}</span>{% endif -%}
{% endmacro %}

{# Shared post-list item, used by the homepage and the tag/topic pages so the
   markup stays in one place. #}
{% macro postItem(post) %}
    <li class="post-list-item">
      <a class="post-link" href="{{ post.url }}">
        <span class="post-date">
          <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        </span>
        <span class="post-title">
          {{ post.data.title }}
          {{- stageBadge(post.data.stage) -}}
        </span>
        <span class="post-arrow" aria-hidden="true">→</span>
      </a>
    </li>
{% endmacro %}

{# Chips linking to each of a post's topic tags (everything except the internal
   "post" tag). #}
{% macro topicTags(tags) %}
{%- if tags and (tags | length) > 1 %}
  <ul class="tag-list">
    {%- for tag in tags %}
    {%- if tag != "post" %}
    <li><a class="tag-chip" href="/tema/{{ tag | slugify }}/">{{ tag }}</a></li>
    {%- endif %}
    {%- endfor %}
  </ul>
{%- endif %}
{% endmacro %}
