{# TEMPORARY — markup for the home-page redesign experiments (/experiment/).
   Delete this file together with src/experiment*.njk and the "EXPERIMENT"
   block in css/style.css to remove the whole experiment. #}
{% from "macros.njk" import stageBadge %}

{# Slug of the curated "start here" pick, so it is not also listed below. #}
{% set CURATED = "preco-tato-stranka-vobec-existuje" %}

{# All variants, for the switcher nav. #}
{% set EXP_VARIANTS = [
  { slug: "", label: "Aktuálna", url: "/" },
  { slug: "a", label: "A", url: "/experiment/a/" },
  { slug: "b", label: "B", url: "/experiment/b/" },
  { slug: "c", label: "C", url: "/experiment/c/" },
  { slug: "d", label: "D", url: "/experiment/d/" },
  { slug: "e", label: "E", url: "/experiment/e/" },
  { slug: "f", label: "F", url: "/experiment/f/" },
  { slug: "g", label: "G", url: "/experiment/g/" },
  { slug: "h", label: "H", url: "/experiment/h/" },
  { slug: "i", label: "I", url: "/experiment/i/" }
] %}

{# The date + status meta line. `order` = "date-first" (date left, status right)
   or "status-first" (status left, date right). #}
{% macro expMetaRow(post, order) %}
        <span class="exp-meta">
          {%- if order == "status-first" %}
          <span class="exp-status">{{ stageBadge(post.data.stage) }}</span>
          <span class="post-date exp-date"><time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time></span>
          {%- else %}
          <span class="post-date exp-date"><time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time></span>
          <span class="exp-status">{{ stageBadge(post.data.stage) }}</span>
          {%- endif %}
        </span>
{% endmacro %}

{# One post row. `mode`:
   - "inline" → original look: date line, then title with inline status badge.
   - "meta"   → date + status share one line (see `order`); title on its own.
   `metaBelow` (meta mode only) puts the meta line below the title. #}
{% macro expPost(post, mode, order, metaBelow) %}
    <li class="post-list-item">
      {%- if mode == "icon" %}
      {%- set s = post.data.stage | stageInfo %}
      <a class="post-link exp-iconrow" href="{{ post.url }}">
        {%- if s %}<span class="exp-icon stage-{{ post.data.stage }}" title="{{ s.label }}" role="img" aria-label="{{ s.label }}">{{ s.emoji }}</span>{% else %}<span class="exp-icon" aria-hidden="true"></span>{%- endif %}
        <span class="post-title exp-title">{{ post.data.title }}</span>
      </a>
      {%- elif mode == "statusTop" %}
      <a class="post-link exp-link" href="{{ post.url }}">
        <span class="exp-status">{{ stageBadge(post.data.stage) }}</span>
        <span class="post-title exp-title">{{ post.data.title }}<span class="exp-date-inline"><time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time></span></span>
      </a>
      {%- elif mode == "meta" %}
      <a class="post-link exp-link" href="{{ post.url }}">
        {%- if not metaBelow %}{{ expMetaRow(post, order) }}{%- endif %}
        <span class="post-title exp-title">{{ post.data.title }}</span>
        {%- if metaBelow %}{{ expMetaRow(post, order) }}{%- endif %}
      </a>
      {%- else %}
      <a class="post-link" href="{{ post.url }}">
        <span class="post-date">
          <time datetime="{{ post.date | htmlDateString }}">{{ post.date | readableDate }}</time>
        </span>
        <span class="post-title">
          {{ post.data.title }}
          {{- stageBadge(post.data.stage) -}}
        </span>
        <span class="post-arrow" aria-hidden="true">→</span>
      </a>
      {%- endif %}
    </li>
{% endmacro %}

{# The full decluttered home body. `rows` renders "Všetky články" as quiet
   divider rows (the curated pick keeps its card). #}
{% macro expHome(posts, slug, label, mode="inline", order="date-first", metaBelow=false, rows=false) %}
<nav class="exp-nav" aria-label="Prepínač variantov">
  <span class="exp-nav-label">Experiment:</span>
  {%- for v in EXP_VARIANTS %}
  <a href="{{ v.url }}"{% if v.slug == slug %} aria-current="page"{% endif %}>{{ v.label }}</a>
  {%- endfor %}
</nav>

<p class="exp-banner">Dočasná ukážka na porovnanie — {{ label }}. Skús ju na telefóne.</p>

<div class="exp exp-{{ slug }}{% if rows %} exp-rows{% endif %}">
  <section class="intro">
    <p class="intro-lead">
      Ahoj, som Gabo a mám (vraj<span class="asterisk">*</span>) depresiu.
    </p>
    <p class="intro-note">
      <span class="asterisk">*</span> „vraj“ pretože s tým ešte stále nie som
      stotožnený a diagnostika depresie žiaľ nie je úplne presná.
    </p>
  </section>

  <section class="start-here">
    <h2 class="page-title">Kde začať?</h2>
    <p class="start-here-lead">
      Toto je moja digitálna záhradka. Keď mám čas, tak sem pridám nejaké drobné
      vylepšenie alebo „zalejem“ (upravím) nejaký článok.
    </p>

    <ul class="post-list">
      {%- for post in posts %}
      {%- if post.fileSlug == CURATED %}
      {{ expPost(post, mode, order, metaBelow) }}
      {%- endif %}
      {%- endfor %}
    </ul>
  </section>

  <section class="posts">
    <h2 class="page-title">Všetky články</h2>

    <ul class="post-list">
      {%- for post in posts | reverse %}
      {%- if post.fileSlug != CURATED %}
      {{ expPost(post, mode, order, metaBelow) }}
      {%- endif %}
      {%- endfor %}
    </ul>
  </section>
</div>
{% endmacro %}
