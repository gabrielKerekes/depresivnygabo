<!DOCTYPE html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {# Reader-mode extractors (Safari/Firefox/Brave use Readability) only strip a
       known set of title separators — | - / \ > » — so the site name is split off
       cleanly in reader view. The interpunct "·" is not recognised and would leak
       into the reader headline. #}
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="author" content="{{ author or site.author }}" />
    <!-- Apply the saved theme before first paint to avoid a flash of the wrong colours -->
    <script>
      (function () {
        var t;
        try {
          t = localStorage.getItem("theme");
        } catch (e) {}
        document.documentElement.setAttribute(
          "data-theme",
          t === "light" || t === "dark" ? t : "system"
        );
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="preload"
      href="/fonts/CheltenhamStdBook.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="{{ site.title }} — Atom feed"
      href="/feed.xml"
    />
    {% if site.cloudflareToken %}
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "{{ site.cloudflareToken }}"}'
    ></script>
    {% endif %}
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">{{ site.title }}</a>
      <div class="header-right">
        {# No nav: the only destination left is home, and the wordmark already
           goes there. Restore a <nav> here when there are pages to link to. #}
        <button type="button" class="theme-toggle" aria-label="Prepnúť tému">
          <svg
            class="icon icon-system"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
          <svg
            class="icon icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4" />
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            />
          </svg>
          <svg
            class="icon icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
          </svg>
        </button>
      </div>
    </header>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <p class="footer-meta">
        So <span class="heart">&lt;3</span> vytvoril
        <a href="https://github.com/{{ site.github }}">Gabo</a> ·
        <a href="https://github.com/{{ site.github }}/depresivnygabo">zdrojový kód na GitHube</a> ·
        <a href="/feed.xml">RSS</a>
      </p>
    </footer>

    <script>
      (function () {
        var btn = document.querySelector(".theme-toggle");
        if (!btn) return;
        var root = document.documentElement;
        var order = ["system", "light", "dark"];
        var labels = {
          system: "Téma: podľa systému",
          light: "Téma: svetlá",
          dark: "Téma: tmavá"
        };

        function apply(mode) {
          root.setAttribute("data-theme", mode);
          btn.setAttribute("aria-label", labels[mode]);
          btn.setAttribute("title", labels[mode]);
          try {
            localStorage.setItem("theme", mode);
          } catch (e) {}
        }

        // Sync the label with whatever the head script already applied
        var current = root.getAttribute("data-theme");
        if (order.indexOf(current) === -1) current = "system";
        btn.setAttribute("aria-label", labels[current]);
        btn.setAttribute("title", labels[current]);

        btn.addEventListener("click", function () {
          apply(order[(order.indexOf(current) + 1) % order.length]);
          current = root.getAttribute("data-theme");
        });
      })();
    </script>

    <!-- Post cards tilt slightly toward the cursor while hovered. Everything
         else about the card (lift, scale, shadow, corner wash) is CSS; this
         only feeds the rotation angles into --rx/--ry. -->
    <script>
      (function () {
        var cards = document.querySelectorAll(".post-list-item");
        if (!cards.length) return;
        // Skip on touch/coarse pointers (nothing to hover) and when the reader
        // has asked for reduced motion.
        if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        // The cards are wide and short, so a degree of rotateY swings the far
        // edge much further than a degree of rotateX moves the top edge. The
        // vertical axis gets 2x the angle to compensate.
        var TILT = 1.5;
        var V_RATIO = 2;

        cards.forEach(function (card) {
          card.addEventListener("pointermove", function (e) {
            var b = card.getBoundingClientRect();
            var px = (e.clientX - b.left) / b.width - 0.5;
            var py = (e.clientY - b.top) / b.height - 0.5;
            card.style.setProperty("--ry", (px * TILT * 2).toFixed(2) + "deg");
            card.style.setProperty("--rx", (-py * TILT * V_RATIO * 2).toFixed(2) + "deg");
          });
          card.addEventListener("pointerleave", function () {
            card.style.removeProperty("--rx");
            card.style.removeProperty("--ry");
          });
        });
      })();
    </script>
  </body>
</html>
