<!DOCTYPE html>
<html lang="sk">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {# Reader-mode extractors (Safari/Firefox/Brave use Readability) only strip a
       known set of title separators — | - / \ > » — so the site name is split off
       cleanly in reader view. The interpunct "·" is not recognised and would leak
       into the reader headline. #}
    <title>{% if title %}{{ title }} | {% endif %}{{ site.title }}</title>
    <meta name="description" content="{{ description or site.description }}" />
    <meta name="author" content="{{ author or site.author }}" />
    <!-- Apply the saved theme before first paint to avoid a flash of the wrong colours -->
    <script>
      (function () {
        var t;
        try {
          t = localStorage.getItem("theme");
        } catch (e) {}
        document.documentElement.setAttribute(
          "data-theme",
          t === "light" || t === "dark" ? t : "system"
        );
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link
      rel="preload"
      href="/fonts/CheltenhamStdBook.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="stylesheet" href="/css/style.css" />
    <link
      rel="alternate"
      type="application/atom+xml"
      title="{{ site.title }} — Atom feed"
      href="/feed.xml"
    />
    {% if site.cloudflareToken %}
    <script
      defer
      src="https://static.cloudflareinsights.com/beacon.min.js"
      data-cf-beacon='{"token": "{{ site.cloudflareToken }}"}'
    ></script>
    {% endif %}
  </head>
  <body>
    <header class="site-header">
      <a class="site-title" href="/">
        <svg
          class="site-leaf"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="16"
          height="16"
          aria-hidden="true"
        >
          <path class="leaf-blade" d="M1 1c13 0 22 9 22 22C10 23 1 14 1 1Z" />
          <path class="leaf-vein" d="M8.6 8.6 14.9 14.9" />
        </svg>
        <span>{{ site.title }}</span>
      </a>
      <div class="header-right">
        <button
          type="button"
          class="nav-toggle"
          aria-label="Otvoriť menu"
          aria-expanded="false"
          aria-controls="side-menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <button type="button" class="theme-toggle" aria-label="Prepnúť tému">
          <svg
            class="icon icon-system"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
            <path d="M8 21h8M12 17v4" />
          </svg>
          <svg
            class="icon icon-sun"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="4" />
            <path
              d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
            />
          </svg>
          <svg
            class="icon icon-moon"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z" />
          </svg>
        </button>
      </div>
    </header>

    <div class="side-menu-backdrop" hidden></div>
    <nav
      id="side-menu"
      class="side-menu"
      aria-label="Hlavné menu"
      aria-hidden="true"
    >
      <div class="side-menu-head">
        <span class="side-menu-title">Menu</span>
        <button type="button" class="side-menu-close" aria-label="Zavrieť menu">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            width="18"
            height="18"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 6 6 18M6 6l12 12" />
          </svg>
        </button>
      </div>
      <ul class="side-menu-list">
        <li><a href="/">Domov</a></li>
        <li><a href="mailto:{{ site.email }}">Kontakt</a></li>
        <li>
          <a href="https://github.com/{{ site.github }}" rel="me noopener">GitHub</a>
        </li>
      </ul>
    </nav>

    <main>
      {{ content | safe }}
    </main>

    <footer class="site-footer">
      <p class="footer-credit">
        So <span class="heart">&lt;3</span> vytvoril
        <a href="https://github.com/{{ site.github }}">Gabo</a>
      </p>
      <nav class="footer-links" aria-label="Odkazy v pätičke">
        <a href="https://github.com/{{ site.github }}/depresivnygabo">zdrojový kód na GitHube</a>
        <span class="footer-sep" aria-hidden="true">·</span>
        <a href="/feed.xml">RSS</a>
      </nav>
    </footer>

    <script>
      (function () {
        var btn = document.querySelector(".theme-toggle");
        if (!btn) return;
        var root = document.documentElement;
        var order = ["system", "light", "dark"];
        var labels = {
          system: "Téma: podľa systému",
          light: "Téma: svetlá",
          dark: "Téma: tmavá"
        };

        function apply(mode) {
          root.setAttribute("data-theme", mode);
          btn.setAttribute("aria-label", labels[mode]);
          btn.setAttribute("title", labels[mode]);
          try {
            localStorage.setItem("theme", mode);
          } catch (e) {}
        }

        // Sync the label with whatever the head script already applied
        var current = root.getAttribute("data-theme");
        if (order.indexOf(current) === -1) current = "system";
        btn.setAttribute("aria-label", labels[current]);
        btn.setAttribute("title", labels[current]);

        btn.addEventListener("click", function () {
          apply(order[(order.indexOf(current) + 1) % order.length]);
          current = root.getAttribute("data-theme");
        });
      })();
    </script>

    <!-- Side menu: hamburger opens an off-canvas drawer; a backdrop, the close
         button, Escape, or picking a link closes it. Focus is trapped inside
         while open and returned to the toggle on close. -->
    <script>
      (function () {
        var toggle = document.querySelector(".nav-toggle");
        var menu = document.getElementById("side-menu");
        var backdrop = document.querySelector(".side-menu-backdrop");
        var closeBtn = document.querySelector(".side-menu-close");
        if (!toggle || !menu || !backdrop) return;

        var isOpen = false;

        function focusable() {
          return menu.querySelectorAll("a[href], button:not([disabled])");
        }

        function open() {
          if (isOpen) return;
          isOpen = true;
          backdrop.hidden = false;
          document.body.classList.add("side-menu-open");
          menu.classList.add("is-open");
          menu.setAttribute("aria-hidden", "false");
          toggle.setAttribute("aria-expanded", "true");
          var first = focusable()[0];
          if (first) first.focus();
          document.addEventListener("keydown", onKeydown);
        }

        function close() {
          if (!isOpen) return;
          isOpen = false;
          document.body.classList.remove("side-menu-open");
          menu.classList.remove("is-open");
          menu.setAttribute("aria-hidden", "true");
          toggle.setAttribute("aria-expanded", "false");
          document.removeEventListener("keydown", onKeydown);
          // Wait for the slide-out transition before hiding the backdrop.
          var done = function () {
            if (!isOpen) backdrop.hidden = true;
            menu.removeEventListener("transitionend", done);
          };
          menu.addEventListener("transitionend", done);
          toggle.focus();
        }

        function onKeydown(e) {
          if (e.key === "Escape") {
            close();
            return;
          }
          if (e.key !== "Tab") return;
          var items = focusable();
          if (!items.length) return;
          var first = items[0];
          var last = items[items.length - 1];
          if (e.shiftKey && document.activeElement === first) {
            e.preventDefault();
            last.focus();
          } else if (!e.shiftKey && document.activeElement === last) {
            e.preventDefault();
            first.focus();
          }
        }

        toggle.addEventListener("click", open);
        backdrop.addEventListener("click", close);
        if (closeBtn) closeBtn.addEventListener("click", close);
        menu.addEventListener("click", function (e) {
          if (e.target.closest("a")) close();
        });
      })();
    </script>

    <!-- Post cards tilt slightly toward the cursor while hovered. Everything
         else about the card (lift, scale, shadow, corner wash) is CSS; this
         only feeds the rotation angles into --rx/--ry. -->
    <script>
      (function () {
        var cards = document.querySelectorAll(".post-list-item");
        if (!cards.length) return;
        // Skip on touch/coarse pointers (nothing to hover) and when the reader
        // has asked for reduced motion.
        if (!window.matchMedia("(hover: hover) and (pointer: fine)").matches) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        // The cards are wide and short, so a degree of rotateY swings the far
        // edge much further than a degree of rotateX moves the top edge. The
        // vertical axis gets 2x the angle to compensate.
        var TILT = 1.5;
        var V_RATIO = 2;

        cards.forEach(function (card) {
          card.addEventListener("pointermove", function (e) {
            var b = card.getBoundingClientRect();
            var px = (e.clientX - b.left) / b.width - 0.5;
            var py = (e.clientY - b.top) / b.height - 0.5;
            card.style.setProperty("--ry", (px * TILT * 2).toFixed(2) + "deg");
            card.style.setProperty("--rx", (-py * TILT * V_RATIO * 2).toFixed(2) + "deg");
          });
          card.addEventListener("pointerleave", function () {
            card.style.removeProperty("--rx");
            card.style.removeProperty("--ry");
          });
        });
      })();
    </script>
  </body>
</html>
