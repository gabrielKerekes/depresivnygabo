---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - post
layout: base.njk
eleventyComputed:
  title: "Téma: {{ tag }}"
# Unpublished alongside /temy/ — see the note there.
permalink: false
eleventyExcludeFromCollections: true
---
{% from "macros.njk" import postItem %}
<section class="posts">
  <p class="back"><a href="/temy/">← všetky témy</a></p>
  <h2 class="page-title">Téma: {{ tag }}</h2>

  <ul class="post-list">
    {%- for post in collections[tag] | reverse %}
    {{ postItem(post) }}
    {%- endfor %}
  </ul>
</section>
